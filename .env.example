# 必填 - 随机生成，至少 32 位
SESSION_SECRET=
CAPTCHA_SECRET_KEY=

# 可选 - 管理员账号（仅首次 setup 时生效）
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe_123456
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NICKNAME=管理员

# 可选 - 服务端口
PORT=3000

# 可选 - 后台任务模式 (worker-only / hybrid / auto)
BACKGROUND_JOB_WEB_RUNTIME=worker-only
