{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next\\/static|_next\\/image|favicon.ico|robots.txt|sitemap.xml|.*\\..*).*))(\\.json|\\.rsc|\\.segments\\/.+\\.segment\\.rsc)?[\\/#\\?]?$",
          "originalSource": "/((?!_next/static|_next/image|favicon.ico|robots.txt|sitemap.xml|.*\\..*).*)"
        }
      ]
    },
    "/api/admin/site-settings/markdown-emoji/upload": {},
    "/api/admin/site-settings/watermark-font-upload": {},
    "/api/admin/site-settings/watermark-logo-upload": {},
    "/api/admin/site-settings/watermark-preview": {},
    "/api/messages/files/[uploadId]/[filename]": {},
    "/api/messages/stream": {},
    "/api/upload/remote-image": {},
    "/uploads/[...path]": {}
  }
}